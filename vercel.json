{
  "version": 2,
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/next" },
    { "src": "api/*.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/analyze", "dest": "/api/analyze" },
    { "src": "/api/backtest_for", "dest": "/api/backtest_for" },
    { "src": "/api/health", "dest": "/api/health" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ],
  "functions": {
    "api/analyze.py": { "maxDuration": 60 },
    "api/backtest_for.py": { "maxDuration": 30 }
  }
}
